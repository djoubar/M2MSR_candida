data <- data |>
arrange(iep, groupehc) |>
group_by(iep, groupehc) |>
slice(1) |>
ungroup() |>
mutate(
resultat_candida_def = factor(resultat_candida_def, levels=c("0","1"), labels=c("0","1"))
)
################################################################################
#                                 4_COMPLETER                                  #
################################################################################
# compléter sexe_féminin
data <- data |>
mutate(
demo_sexe = case_when(
iep %in% c("16123204" , "22517597" , "14926498") ~ "Féminin",
TRUE ~ demo_sexe)
)
# compléter sexe masculin
data <- data |>
mutate(
demo_sexe = case_when(
iep %in% c("23175309" , "22842308" , "22513578" , "22470648" , "22445608" , "16005104" , "14814310") ~ "Masculin",
TRUE ~ demo_sexe)
)
View(data)
names(data)
.data.imp <- data[,c(10:112)]
.data.mice <- mice(.data.imp, seed = 1)
#| label: tbl_NA
#| print: TRUE
colSums(is.na(data))
View(data)
table(data$resultat_candida_def)
rm (list = ls())
source("scripts/_setup.R")
data <- data |>
select(iep, demo_centre, resultat_candida_def, hc_glucanes_max, hc_mannanes_max, hc_cgr,
hc_pfc, hc_cp, hc_vvc, hc_vi_cat, hc_dialyse, hc_neutro_min,
demo_atcd_diabete, hospit_fibro, hc_noradre) |>
na.omit(data)
mod_1 <- glmer(data = data,
family = "binomial",
resultat_candida_def ~ hc_dialyse + hc_cgr)
mod_1 <- glmer(data = data,
family = "binomial",
resultat_candida_def ~ hc_dialyse + hc_cgr + (1|iep))
mod_step <- step(mod_1,
scope = list(c(~demo_centre+ resultat_candida_def+ hc_glucanes_max+ hc_mannanes_max+
hc_pfc+ hc_cp+ hc_vvc+ hc_vi_cat+ hc_neutro_min+
demo_atcd_diabete+ hospit_fibro+ hc_noradre)))
mod_step <- step(mod_1,
scope = list(c(~demo_centre+ hc_glucanes_max+ hc_mannanes_max+
hc_pfc+ hc_cp+ hc_vvc+ hc_vi_cat+ hc_neutro_min+
demo_atcd_diabete+ hospit_fibro+ hc_noradre)))
mod_full <- glmer(
resultat_candida_def ~
hc_dialyse + hc_cgr + demo_centre +
hc_glucanes_max + hc_mannanes_max +
hc_pfc + hc_cp + hc_vvc + hc_vi_cat +
hc_neutro_min + demo_atcd_diabete +
hospit_fibro + hc_noradre +
(1 | iep),
data = df,
family = binomial
)
mod_full <- glmer(
resultat_candida_def ~
hc_dialyse + hc_cgr + demo_centre +
hc_glucanes_max + hc_mannanes_max +
hc_pfc + hc_cp + hc_vvc + hc_vi_cat +
hc_neutro_min + demo_atcd_diabete +
hospit_fibro + hc_noradre +
(1 | iep),
data = data,
family = "binomial"
)
anova(mod_1, mod_full)
mod_red <- update(mod_full, . ~ . - hc_cp)
anova(mod_red, mod_full)
